# Copy this file to .env.local and fill in your values

# Supabase — from https://supabase.com/dashboard/project/<your-project>/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://jahppennwbgcwfmqlgqh.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Groq — from https://console.groq.com/keys
# Used by Supabase Edge Functions — NOT the mobile app directly
# Set in: Supabase Dashboard > Edge Functions > Secrets
# supabase secrets set GROQ_API_KEY=gsk_... --project-ref jahppennwbgcwfmqlgqh
# Optional model overrides:
# supabase secrets set GROQ_MODEL=llama-3.3-70b-versatile --project-ref jahppennwbgcwfmqlgqh
# supabase secrets set GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct --project-ref jahppennwbgcwfmqlgqh
# supabase secrets set GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo --project-ref jahppennwbgcwfmqlgqh
# supabase secrets set GROQ_TEXT_MODEL=llama-3.3-70b-versatile --project-ref jahppennwbgcwfmqlgqh
# Optional for nightly catalog sync endpoint protection:
# supabase secrets set FOOD_SYNC_SECRET=your-random-secret --project-ref jahppennwbgcwfmqlgqh

# RevenueCat (iOS subscriptions) — from RevenueCat dashboard
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_revenuecat_key

# Sentry crash reporting (optional in dev)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# App Store / support (update with your real domain and inbox)
EXPO_PUBLIC_SUPPORT_EMAIL=shripad0304@gmail.com
EXPO_PUBLIC_PRIVACY_URL=https://shripad3.github.io/plates-and-reps/privacy/
EXPO_PUBLIC_TERMS_URL=https://shripad3.github.io/plates-and-reps/terms/

# RevenueCat webhook secret (Supabase Edge Function only):
# supabase secrets set REVENUECAT_WEBHOOK_SECRET=your-webhook-secret --project-ref jahppennwbgcwfmqlgqh
# RevenueCat secret API key (for sync-revenuecat-premium edge function):
# supabase secrets set REVENUECAT_SECRET_KEY=sk_... --project-ref jahppennwbgcwfmqlgqh
